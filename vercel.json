{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/pix",
      "destination": "/api/pix/create"
    },
    {
      "source": "/transactions/:transactionId",
      "destination": "/api/pix/status?transactionId=:transactionId"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/"
    }
  ]
}
